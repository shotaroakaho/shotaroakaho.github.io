{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Hugo: Start local preview",
      "type": "shell",
      "command": "hugo server --disableFastRender --bind 0.0.0.0 --port 1313",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "hugo",
          "severity": "info",
          "pattern": {
            "regexp": ".*",
            "message": 0
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*Web Server is available.*",
            "endsPattern": ".*Press Ctrl\\+C to stop.*"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Hugo: Build site",
      "type": "shell",
      "command": "hugo --gc --minify",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": "build"
    },
    {
      "label": "Hugo: Build and index",
      "type": "shell",
      "command": "pnpm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": "build"
    }
  ]
}
